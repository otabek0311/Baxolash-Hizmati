# MA'LUMOTLAR BAZASI
# Dev:        postgresql://postgres:PAROL@localhost:5432/qrhujjat
# Production: postgresql://postgres:PAROL@SERVER_IP:5432/qrhujjat
DATABASE_URL="postgresql://postgres:PAROL@localhost:5432/qrhujjat"

# JWT — production da uzoq murakkab kalit ishlating
JWT_SECRET="o'zgartiring-kamida-32-belgi"
JWT_EXPIRES_IN="7d"

# SERVER
PORT=5000
NODE_ENV="production"

# URL LAR
# Dev:        http://localhost:5000
# Production: https://api.sizningdomen.uz  yoki  http://SERVER_IP:5000
BASE_URL="http://localhost:5000"

# CORS — frontend qaysi domendan kelishiga ruxsat
# Bir nechta: https://app.uz,https://www.app.uz
CORS_ORIGIN="http://localhost:3010"

# AI
GEMINI_API_KEY="Google AI Studio dan olingan kalit"
GEMINI_API_KEY_2=""
GEMINI_API_KEY_3=""

# SEED — birinchi deploy uchun parollar (keyin o'chiring)
SUPERADMIN_PASSWORD="kuchli-parol-kiriting"
ADMIN_PASSWORD="kuchli-parol-kiriting"

# FAYL SOZLAMALARI
DEFAULT_RETENTION_DAYS=30
MIN_RETENTION_DAYS=7
MAX_RETENTION_DAYS=90
MAX_FILE_SIZE_MB=150
